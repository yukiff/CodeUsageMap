<UserControl x:Class="CodeUsageMap.Vsix.ToolWindows.UsageMapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </UserControl.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="320" />
      <RowDefinition Height="*" />
      <RowDefinition Height="180" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <TextBlock Grid.Row="0"
               Grid.ColumnSpan="3"
               FontSize="16"
               FontWeight="SemiBold"
               Text="{Binding Title}" />

    <TextBlock Grid.Row="1"
               Grid.ColumnSpan="3"
               Margin="0,6,0,12"
               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
               Text="{Binding Summary}" />

    <DockPanel Grid.Row="2"
               Grid.ColumnSpan="3"
               Margin="0,0,0,12">
      <StackPanel DockPanel.Dock="Right"
                  Orientation="Horizontal">
        <Button Width="110"
                Margin="12,0,0,0"
                Command="{Binding ExportJsonCommand}"
                Content="Export JSON" />
        <Button Width="140"
                Margin="12,0,0,0"
                Command="{Binding ExportViewModelJsonCommand}"
                Content="Export ViewModel" />
        <Button Width="110"
                Margin="12,0,0,0"
                Command="{Binding ExportDgmlCommand}"
                Content="Export DGML" />
        <Button Width="100"
                Margin="12,0,0,0"
                Command="{Binding ClearFiltersCommand}"
                Content="Clear Filters" />
        <Button Width="100"
                Margin="12,0,0,0"
                Command="{Binding RefreshAnalysisCommand}"
                Content="Refresh" />
        <Button Width="100"
                Margin="12,0,0,0"
                Command="{Binding CancelAnalysisCommand}"
                Content="Cancel" />
      </StackPanel>
      <StackPanel>
        <WrapPanel Margin="0,0,0,4">
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Search" />
          <TextBox Width="240"
                   Margin="0,0,12,0"
                   Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Project" />
          <ComboBox Width="220"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableProjectNames}"
                    SelectedItem="{Binding SelectedProjectName, Mode=TwoWay}" />
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Namespace" />
          <ComboBox Width="260"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableNamespaceNames}"
                    SelectedItem="{Binding SelectedNamespaceName, Mode=TwoWay}" />
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Access" />
          <ComboBox Width="180"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableAccessibilities}"
                    SelectedItem="{Binding SelectedAccessibility, Mode=TwoWay}" />
        </WrapPanel>
        <WrapPanel Margin="0,0,0,4">
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Mode" />
          <ComboBox Width="160"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableDisplayModes}"
                    SelectedItem="{Binding SelectedDisplayMode, Mode=TwoWay}" />
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Edge" />
          <ComboBox Width="180"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableEdgeKinds}"
                    SelectedItem="{Binding SelectedEdgeKind, Mode=TwoWay}" />
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Node" />
          <ComboBox Width="180"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableNodeKinds}"
                    SelectedItem="{Binding SelectedNodeKind, Mode=TwoWay}" />
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Depth" />
          <ComboBox Width="64"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableDepths}"
                    SelectedItem="{Binding SelectedDepth, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Exclude tests"
                    IsChecked="{Binding ExcludeTests, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Hide external"
                    IsChecked="{Binding ExcludeExternalSymbols, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Hide System.*"
                    IsChecked="{Binding ExcludeSystemSymbols, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Hide NuGet"
                    IsChecked="{Binding ExcludePackageSymbols, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Highlight interface"
                    IsChecked="{Binding HighlightInterfaceFlow, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Highlight events"
                    IsChecked="{Binding HighlightEventFlow, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Highlight async"
                    IsChecked="{Binding HighlightAsyncFlow, Mode=TwoWay}" />
          <TextBlock Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="Canvas nodes" />
          <ComboBox Width="76"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableCanvasNodeLimits}"
                    SelectedItem="{Binding SelectedCanvasNodeLimit, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Focus mode"
                    IsChecked="{Binding CanvasFocusMode, Mode=TwoWay}" />
          <TextBlock Margin="12,0,8,0"
                     VerticalAlignment="Center"
                     Text="Min confidence" />
          <ComboBox Width="90"
                    Margin="0,0,12,0"
                    ItemsSource="{Binding AvailableConfidenceThresholds}"
                    SelectedItem="{Binding SelectedMinimumConfidence, Mode=TwoWay}" />
          <CheckBox Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Content="Follow caret"
                    IsChecked="{Binding FollowCaret, Mode=TwoWay}" />
          <CheckBox VerticalAlignment="Center"
                    Content="Exclude generated"
                    IsChecked="{Binding ExcludeGenerated, Mode=TwoWay}" />
        </WrapPanel>
        <TextBlock Text="{Binding StatusMessage}" />
        <TextBlock Foreground="IndianRed"
                   Text="{Binding ErrorMessage}" />
        <ItemsControl Margin="0,6,0,0"
                      ItemsSource="{Binding Diagnostics}"
                      Visibility="{Binding HasDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,4"
                      Padding="6"
                      Background="#11CC7A00"
                      BorderBrush="#33CC7A00"
                      BorderThickness="1">
                <StackPanel>
                  <TextBlock FontWeight="SemiBold"
                             Text="{Binding Code}" />
                  <TextBlock Text="{Binding Message}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DockPanel>

    <GroupBox Grid.Row="3"
              Grid.ColumnSpan="3"
              Margin="0,0,0,12"
              Header="Symbol Candidates"
              Visibility="{Binding HasSymbolCandidates, Converter={StaticResource BooleanToVisibilityConverter}}">
      <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Right"
                    Margin="12,0,0,0">
          <Button Width="180"
                  Command="{Binding AnalyzeSelectedCandidateCommand}"
                  Content="Analyze Selected Candidate" />
        </StackPanel>
        <ListBox ItemsSource="{Binding SymbolCandidates}"
                 SelectedItem="{Binding SelectedSymbolCandidate, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,8">
                <TextBlock FontWeight="SemiBold"
                           Text="{Binding DisplayName}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ProjectName}" />
                <TextBlock Text="{Binding MatchKind, StringFormat=Match: {0}}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </GroupBox>

    <GroupBox Grid.Row="4"
              Grid.ColumnSpan="3"
              Margin="0,0,0,12"
              Header="Graph Canvas Preview"
              Visibility="{Binding HasGraphCanvas, Converter={StaticResource BooleanToVisibilityConverter}}">
      <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,8">
          <WrapPanel Margin="0,0,0,8">
            <Button Width="80"
                    Margin="0,0,8,0"
                    Click="GraphCanvas_ZoomInClick"
                    Content="Zoom In" />
            <Button Width="80"
                    Margin="0,0,8,0"
                    Click="GraphCanvas_ZoomOutClick"
                    Content="Zoom Out" />
            <Button Width="90"
                    Margin="0,0,12,0"
                    Click="GraphCanvas_ResetViewClick"
                    Content="Reset View" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="Ctrl + Wheel: Zoom / Middle Drag: Pan / Right Click: Menu" />
          </WrapPanel>
          <ItemsControl ItemsSource="{Binding BreadcrumbItems}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,6,6"
                        Padding="8,4"
                        Background="#FFF7F9FC"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="10">
                  <TextBlock Text="{Binding Label}" />
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
          </Grid.ColumnDefinitions>

          <ScrollViewer x:Name="GraphCanvasScrollViewer"
                        Grid.Column="0"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        PreviewMouseWheel="GraphCanvas_PreviewMouseWheel"
                        ScrollChanged="GraphCanvasScrollViewer_ScrollChanged"
                        SizeChanged="GraphCanvasScrollViewer_SizeChanged">
            <Border x:Name="GraphCanvasViewport"
                    Background="#FFF9FBFD"
                    MouseDown="GraphCanvas_MouseDown"
                    MouseMove="GraphCanvas_MouseMove"
                    MouseUp="GraphCanvas_MouseUp"
                    MouseLeave="GraphCanvas_MouseLeave">
              <Grid Width="{Binding GraphCanvasWidth}"
                    Height="{Binding GraphCanvasHeight}"
                    RenderTransformOrigin="0,0">
                <Grid.RenderTransform>
                  <ScaleTransform x:Name="GraphCanvasScaleTransform" />
                </Grid.RenderTransform>
                <ItemsControl ItemsSource="{Binding GraphCanvasEdges}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Path Data="{Binding PathData}"
                            Stroke="{Binding Stroke}"
                            StrokeThickness="{Binding StrokeThickness}"
                            Opacity="{Binding Opacity}"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round"
                            SnapsToDevicePixels="True" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding GraphCanvasNodes}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                      <Setter Property="Canvas.Left" Value="{Binding Left}" />
                      <Setter Property="Canvas.Top" Value="{Binding Top}" />
                    </Style>
                  </ItemsControl.ItemContainerStyle>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Width="{Binding Width}"
                              Height="{Binding Height}"
                              Padding="8"
                              Background="{Binding Fill}"
                              Opacity="{Binding Opacity}"
                              BorderBrush="{Binding BorderBrush}"
                              BorderThickness="{Binding BorderThickness}"
                              CornerRadius="8"
                              MouseLeftButtonDown="CanvasNode_MouseLeftButtonDown"
                              MouseRightButtonDown="CanvasNode_MouseRightButtonDown">
                        <Border.ContextMenu>
                          <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Open"
                                      Click="CanvasNode_OpenClick" />
                            <MenuItem Header="Reroot"
                                      Click="CanvasNode_RerootClick" />
                            <MenuItem Header="{Binding CollapseButtonLabel}"
                                      Click="CanvasNode_CollapseClick" />
                          </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel>
                          <DockPanel Margin="0,0,0,6">
                            <Border Width="20"
                                    Height="20"
                                    Margin="0,0,8,0"
                                    Background="{Binding BorderBrush}"
                                    CornerRadius="10">
                              <TextBlock HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         FontSize="11"
                                         FontWeight="Bold"
                                         Foreground="White"
                                         Text="{Binding KindLabel}" />
                            </Border>
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis" />
                          </DockPanel>
                          <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                     Text="{Binding ProjectName}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                     Text="{Binding Lane}"
                                     TextTrimming="CharacterEllipsis" />
                          <WrapPanel Margin="0,8,0,0">
                            <Button Width="56"
                                    Margin="0,0,8,0"
                                    Click="CanvasNode_OpenClick"
                                    Content="Open" />
                            <Button Width="60"
                                    Margin="0,0,8,0"
                                    Click="CanvasNode_RerootClick"
                                    Content="Reroot" />
                            <Button Width="68"
                                    IsEnabled="{Binding HasChildren}"
                                    Click="CanvasNode_CollapseClick"
                                    Content="{Binding CollapseButtonLabel}" />
                          </WrapPanel>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </Border>
          </ScrollViewer>

          <StackPanel Grid.Column="1"
                      Margin="12,0,0,0">
            <TextBlock Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Text="Legend" />
            <ItemsControl Margin="0,0,0,12"
                          ItemsSource="{Binding LegendItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <DockPanel Margin="0,0,0,8">
                    <Border Width="14"
                            Height="14"
                            Margin="0,2,8,0"
                            Background="{Binding Swatch}"
                            CornerRadius="3" />
                    <StackPanel>
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding Label}" />
                      <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                 Text="{Binding Description}"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </DockPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Text="Mini Map" />
            <Border Padding="8"
                    Background="#FFFDFDFD"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1"
                    CornerRadius="6">
              <Canvas Width="{Binding MiniMapWidth}"
                      Height="{Binding MiniMapHeight}">
                <ItemsControl ItemsSource="{Binding MiniMapNodes}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                      <Setter Property="Canvas.Left" Value="{Binding Left}" />
                      <Setter Property="Canvas.Top" Value="{Binding Top}" />
                    </Style>
                  </ItemsControl.ItemContainerStyle>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Width="{Binding Width}"
                              Height="{Binding Height}"
                              Background="{Binding Fill}"
                              Opacity="{Binding Opacity}"
                              CornerRadius="2" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Width="{Binding MiniMapViewportWidth}"
                        Height="{Binding MiniMapViewportHeight}"
                        BorderBrush="#FFAA3A3A"
                        BorderThickness="1.5"
                        Background="#11AA3A3A"
                        CornerRadius="2"
                        Canvas.Left="{Binding MiniMapViewportLeft}"
                        Canvas.Top="{Binding MiniMapViewportTop}" />
              </Canvas>
            </Border>
          </StackPanel>
        </Grid>
      </DockPanel>
    </GroupBox>

    <Grid Grid.Row="5" Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="220" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <GroupBox Grid.Row="0"
                Header="Root Search"
                Margin="0,0,0,12">
        <DockPanel Margin="8">
          <StackPanel DockPanel.Dock="Top"
                      Margin="0,0,0,8">
            <WrapPanel Margin="0,0,0,8">
              <TextBox Width="220"
                       Margin="0,0,8,0"
                       Text="{Binding RootSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              <Button Width="96"
                      Margin="0,0,8,0"
                      Command="{Binding ApplySelectedRootSearchResultCommand}"
                      Content="Set As Root" />
              <Button Width="72"
                      Command="{Binding ClearRootSearchCommand}"
                      Content="Clear" />
            </WrapPanel>
            <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="{Binding RootSearchStatusMessage}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <ListBox ItemsSource="{Binding RootSearchResults}"
                   MouseDoubleClick="RootSearchResults_MouseDoubleClick"
                   SelectedItem="{Binding SelectedRootSearchResult, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,8">
                  <TextBlock FontWeight="SemiBold"
                             Text="{Binding DisplayName}"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ProjectName}" />
                  <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                             Text="{Binding Kind}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </GroupBox>

      <GroupBox Grid.Row="1"
                Header="Incoming">
        <DockPanel Margin="8">
          <Button DockPanel.Dock="Top"
                  Width="120"
                  Margin="0,0,0,8"
                  Command="{Binding OpenSelectedRelationCommand}"
                  Content="Open Location" />
          <ListBox ItemsSource="{Binding IncomingRelations}"
                   SelectedItem="{Binding SelectedRelation, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,8">
                  <StackPanel.Opacity>
                    <Binding Path="Opacity" />
                  </StackPanel.Opacity>
                  <TextBlock FontWeight="SemiBold" Text="{Binding SourceDisplayName}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Label}" />
                  <TextBlock Text="{Binding ProjectName}" />
                  <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="{Binding Confidence, StringFormat=Confidence: {0:F2}}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </GroupBox>
    </Grid>

    <GroupBox Grid.Row="5" Grid.Column="1" Header="Root And Outgoing" Margin="12,0">
      <Grid Margin="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,12">
          <Button Width="120"
                  HorizontalAlignment="Left"
                  Margin="0,0,0,8"
                  Command="{Binding OpenSelectedNodeCommand}"
                  Content="Open Root" />
          <Border Padding="8"
                  BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock FontWeight="SemiBold"
                         Text="{Binding RootNode.DisplayName}"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding RootNode.Kind}" />
              <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                         Text="{Binding RootNode.ProjectName}" />
            </StackPanel>
          </Border>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,8"
                   FontWeight="SemiBold"
                   Text="Outgoing" />

        <DockPanel Grid.Row="2">
          <Button DockPanel.Dock="Top"
                  Width="120"
                  Margin="0,0,0,8"
                  Command="{Binding OpenSelectedRelationCommand}"
                  Content="Open Location" />
          <ListBox ItemsSource="{Binding OutgoingRelations}"
                   SelectedItem="{Binding SelectedRelation, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,8">
                  <StackPanel.Opacity>
                    <Binding Path="Opacity" />
                  </StackPanel.Opacity>
                  <TextBlock FontWeight="SemiBold" Text="{Binding TargetDisplayName}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Label}" />
                  <TextBlock Text="{Binding ProjectName}" />
                  <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="{Binding Confidence, StringFormat=Confidence: {0:F2}}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="5" Grid.Column="2" Header="Related">
      <DockPanel Margin="8">
        <Button DockPanel.Dock="Top"
                Width="120"
                Margin="0,0,0,8"
                Command="{Binding OpenSelectedRelationCommand}"
                Content="Open Location" />
        <ListBox ItemsSource="{Binding RelatedRelations}"
                 SelectedItem="{Binding SelectedRelation, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,8">
                <StackPanel.Opacity>
                  <Binding Path="Opacity" />
                </StackPanel.Opacity>
                <TextBlock FontWeight="SemiBold" Text="{Binding SourceDisplayName}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding TargetDisplayName}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding ProjectName}" />
                <TextBlock Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="{Binding Label}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </GroupBox>

    <GroupBox Grid.Row="6" Grid.ColumnSpan="3" Header="Details" Margin="0,12,0,0">
      <Grid Margin="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.3*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="1.3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Margin="0,0,12,0">
          <Button Width="120"
                  HorizontalAlignment="Left"
                  Margin="0,0,0,8"
                  Command="{Binding OpenSelectedNodeCommand}"
                  Content="Open Selected" />

          <TextBlock FontSize="15"
                     FontWeight="SemiBold"
                     Text="{Binding SelectedNodeTitle}"
                     TextWrapping="Wrap" />
          <TextBlock Margin="0,4,0,0"
                     Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                     Text="{Binding SelectedNodeSubtitle}"
                     TextWrapping="Wrap" />
          <TextBlock Margin="0,8,0,0"
                     FontWeight="SemiBold"
                     Text="{Binding SelectedNodeProject}"
                     TextWrapping="Wrap" />
          <TextBlock Margin="0,6,0,0"
                     Visibility="{Binding HasSelectedNodeLocation, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Text="{Binding SelectedNodeLocation}"
                     TextWrapping="Wrap" />
          <TextBlock Margin="0,6,0,0"
                     FontFamily="Consolas"
                     Visibility="{Binding HasSelectedNodeSignature, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Text="{Binding SelectedNodeSignature}"
                     TextWrapping="Wrap" />

          <Border Margin="0,10,0,0"
                  Padding="8"
                  Background="#FFF7F9FC"
                  BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Visibility="{Binding HasSelectedNodeSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding SelectedNodeSummaryText}"
                       TextWrapping="Wrap" />
          </Border>

          <TextBlock Margin="0,12,0,8"
                     FontWeight="SemiBold"
                     Text="Stats"
                     Visibility="{Binding HasSelectedNodeStats, Converter={StaticResource BooleanToVisibilityConverter}}" />
          <ItemsControl ItemsSource="{Binding SelectedNodeStats}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,8,8"
                        Padding="8,6"
                        Background="#FFF7F9FC"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="{Binding Label}" />
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Value}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Margin="0,4,0,8"
                     FontWeight="SemiBold"
                     Text="Impact Summary"
                     Visibility="{Binding HasSelectedNodeImpactSummary, Converter={StaticResource BooleanToVisibilityConverter}}" />
          <ItemsControl ItemsSource="{Binding SelectedNodeImpactSummary}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,8,8"
                        Padding="8,6"
                        Background="#FFF8FCF7"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="{Binding Label}" />
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Value}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Margin="0,4,0,8"
                     FontWeight="SemiBold"
                     Text="Risk Summary"
                     Visibility="{Binding HasSelectedNodeRiskSummary, Converter={StaticResource BooleanToVisibilityConverter}}" />
          <ItemsControl ItemsSource="{Binding SelectedNodeRiskSummary}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,8,8"
                        Padding="8,6"
                        Background="#FFFCF7F7"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="{Binding Label}" />
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Value}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <DockPanel Grid.Column="1"
                   Margin="0,0,12,0">
          <TextBlock DockPanel.Dock="Top"
                     Margin="0,0,0,8"
                     FontWeight="SemiBold"
                     Text="Highlights" />
          <Border Padding="8"
                  Background="#FFFDFDFD"
                  BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                  BorderThickness="1"
                  CornerRadius="6">
            <ListBox ItemsSource="{Binding SelectedNodeHighlights}"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,8">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Key}" />
                    <TextBlock Text="{Binding Value}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
        </DockPanel>

        <DockPanel Grid.Column="2">
          <TextBlock DockPanel.Dock="Top"
                     Margin="0,0,0,8"
                     FontWeight="SemiBold"
                     Text="Raw Properties" />
          <ListView ItemsSource="{Binding Details}">
            <ListView.View>
              <GridView>
                <GridViewColumn Width="180" Header="Key" DisplayMemberBinding="{Binding Key}" />
                <GridViewColumn Width="420" Header="Value" DisplayMemberBinding="{Binding Value}" />
              </GridView>
            </ListView.View>
          </ListView>
        </DockPanel>
      </Grid>
    </GroupBox>
  </Grid>
</UserControl>
